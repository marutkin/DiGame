{
  "version": 1,
  "dialogues": {
    "dima_meet": {
      "id": "dima_meet",
      "speaker": "Дима",
      "portrait": "dima",
      "lines": [
        { "text": "Привет. Я документы смотрел." },
        { "text": "Она умудрилась сделать так, что мы теперь знаем венгерское миграционное право лучше, чем свои паспортные данные." },
        { "text": "«Быстро и качественно», говорила." },
        { "text": "Год жизни, на чемоданах!." },
        { "text": "Самое обидное даже не отказ а тягомотина из за Людмилы!" }
      ],
      "choices": [
        {
          "text": "Ладно. Хватит. Идём мстить или будешь дальше листы перебирать?",
          "next": "dima_quest"
        }
      ]
    },
    "dima_quest": {
      "id": "dima_quest",
      "speaker": "Дима",
      "portrait": "dima",
      "lines": [
        { "text": "Идём. Вместе дадим им пизды." },
        { "text": "Разберёмся с венграми по дороге и положим конец Людмиле." }
      ],
      "choices": [
        {
          "text": "Вперёд.",
          "next": "dima_quest_given"
        }
      ]
    },
    "dima_quest_given": {
      "id": "dima_quest_given",
      "speaker": "Дима",
      "portrait": "dima",
      "lines": [
        { "text": "Я с тобой." }
      ],
      "end": true,
      "flags": {
        "questStarted": true,
        "dimaJoined": true
      }
    },
    "plyusha_meet": {
