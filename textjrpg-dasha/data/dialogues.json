    "epilogue_final": {
      "id": "epilogue_final",
      "speaker": "Даша",
      "portrait": "dasha",
      "lines": [
        { "text": "Короче. Мы год потеряли из-за одного человека. Но пофиг." },
        { "text": "Поедем лучше в Лондон на день рождения." },
        { "text": "Дима: Согласен. Главное — мы это сделали." },
        { "text": "Людмила (лёжа среди бумаг): Не пишите мне больше, но подписывайтесь на мой канал!" },
        { "text": "С днём рождения, Любимая ❤️" }
      ],
      "end": true,
