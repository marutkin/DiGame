    "enemy_encounter_1": {
      "id": "enemy_encounter_1",
      "speaker": "Венгерский воин",
      "portrait": "enemy_common",
      "lines": [
        { "text": "Вы на ВНЖ подавались?" },
        { "text": "И что сказали?" }
      ],
      "choices": [
        {
          "text": "Послали.",
          "next": "enemy_fight_start"
        }
      ]
    },
    "enemy_fight_start": {
      "id": "enemy_fight_start",
      "speaker": "Венгерский воин",
      "portrait": "enemy_common",
      "lines": [
        { "text": "А, ну тогда всё по плану. Идите дальше. Может, повезёт. А может, и нет." }
      ],
      "end": true,
      "flags": {
        "startCombat": "common"
      }
    },
    "ludmila_intro": {
      "id": "ludmila_intro",
      "speaker": "Людмила Конюхова",
      "portrait": "ludmila",
      "lines": [
        { "text": "О, какие люди! Решили без меня обойтись? Я думала, вы уже в Грузии ИП открываете." },
        { "text": "Людмила. Год." }
      ],
      "choices": [
        {
          "text": "Ты серьёзно сейчас?",
          "next": "ludmila_why"
        },
        {
          "text": "Твоим планам конец, Людмила!",
          "next": "ludmila_fight"
        }
      ]
    },
    "ludmila_why": {
      "id": "ludmila_why",
      "speaker": "Людмила Конюхова",
      "portrait": "ludmila",
      "lines": [
        { "text": "Год — это инвестиция в характер! Вы теперь сильнее." },
        { "text": "Я вам опыт подарила! Теперь вы эксперты. Можете канал запускать «Как потерять год и не сойти с ума»." }
      ],
      "choices": [
        {
          "text": "Знаешь, что самое смешное? Мы теперь систему лучше тебя знаем.",
          "next": "ludmila_fight"
        }
      ]
    },
    "ludmila_fight": {
      "id": "ludmila_fight",
      "speaker": "Людмила Конюхова",
      "portrait": "ludmila",
      "lines": [
        { "text": "Это было низко. Ладно. Давайте драться." }
      ],
      "end": true,
      "flags": {
        "startCombat": "boss"
      }
    },
    "victory_epilogue": {
      "id": "victory_epilogue",
      "speaker": "Людмила Конюхова",
      "portrait": "ludmila",
      "lines": [
        { "text": "Хорошо... вы победили. Но я была эпичным злодеем." }
      ],
      "next": "epilogue_dasha"
    },
    "epilogue_dasha": {
      "id": "epilogue_dasha",
      "speaker": "Даша",
      "portrait": "dasha",
      "lines": [
        { "text": "Ты была эпичным геморроем." }
      ],
      "next": "epilogue_dima"
    },
    "epilogue_dima": {
      "id": "epilogue_dima",
      "speaker": "Дима",
      "portrait": "dima",
      "lines": [
        { "text": "Самым дорогим в нашей жизни." }
      ],
      "next": "epilogue_plusha"
    },
    "epilogue_plusha": {
      "id": "epilogue_plusha",
      "speaker": "Плюша",
      "portrait": "plusha",
      "lines": [
        { "text": "Гав! (Я бы покусала, но даже у меня есть вкус.)" }
      ],
      "next": "epilogue_final"
